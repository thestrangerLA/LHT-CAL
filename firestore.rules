rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: tourCalculations
    // Fields:
    //   - uid: string (required)
    //   - name: string (required)
    //   - days: number (required)
    //   - markupPercentage: number
    //   - markupAmount: number
    //   - createdAt: timestamp (required)
    //   - exchangeRates: map
    //   - costs: map
    //   - tourInfo: map
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isAdmin() {
      return isAuthenticated() && 
             request.auth.token.email == "laohugtravelwork@gmail.com";
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    function isValidTourCalculation(data) {
      return data.uid is string || isAdmin();
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /tourCalculations/{calculationId} {
      allow read: if true;
      allow create: if isAuthenticated() && (uidUnchanged() || isAdmin());
      allow update: if isDocOwner() || isAdmin();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
    
    match /stockItems/{itemId} {
      allow read, write: if isAuthenticated();
    }

    match /tourPrograms/{programId} {
      allow read, write: if isAuthenticated();
    }

    match /tourCostItems/{itemId} {
      allow read, write: if isAuthenticated();
    }

    match /tourIncomeItems/{itemId} {
      allow read, write: if isAuthenticated();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
