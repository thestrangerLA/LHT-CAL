{
  "entities": {
    "TourCalculation": {
      "title": "Tour Calculation",
      "description": "A saved tour cost calculation",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "days": { "type": "number" },
        "markupPercentage": { "type": "number" },
        "markupAmount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "exchangeRates": { "type": "object" },
        "costs": { "type": "object" },
        "uid": { "type": "string" }
      },
      "required": ["uid", "name", "days", "createdAt"]
    }
  },
  "firestore": {
    "/tourCalculations/{calculationId}": {
      "schema": "TourCalculation",
      "description": "Collection of tour cost calculations"
    },
    "/stockItems/{itemId}": {
      "schema": "object",
      "description": "Collection of stock items"
    },
    "/tourPrograms/{programId}": {
      "schema": "object",
      "description": "Collection of tour programs"
    },
    "/tourCostItems/{itemId}": {
      "schema": "object",
      "description": "Collection of tour cost items"
    },
    "/tourIncomeItems/{itemId}": {
      "schema": "object",
      "description": "Collection of tour income items"
    }
  }
}
